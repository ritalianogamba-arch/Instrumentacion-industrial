    "enabled": false,
    "description": "Si es False, aplica fórmula de escalamiento: °C = (raw × 75/1000) + 0.5. Si es True, el PLC envía valores ya escalados.",
    "formula": {
      "disabled": "degrees_celsius = (raw_value * 75 / 1000) + 0.5",
      "enabled": "degrees_celsius = raw_value (already scaled in PLC)"
    }
  },
