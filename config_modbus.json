    "enabled": false,
    "description": "Si es False, convierte presión a % usando min/max del tanque. Si es True, el PLC envía % directamente.",
    "formula": {
      "disabled": "level_percent = ((raw - cfg_min) / (cfg_max - cfg_min)) * 100",
      "enabled": "level_percent = raw_value (already in percentage)"
    }
